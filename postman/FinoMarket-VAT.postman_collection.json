{
  "info": {
    "name": "FinoMarket VAT Calculation Service",
    "description": "Cross-border VAT calculation and compliance audit API. Set the `baseUrl` collection variable if the service is not on localhost:8080.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Calculate - LATAM to EU digital B2C (buyer country VAT)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/tax/calculate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sellerCountry\": \"MX\",\n  \"buyerCountry\": \"DE\",\n  \"productType\": \"DIGITAL\",\n  \"transactionType\": \"B2C\",\n  \"netAmount\": 100.0,\n  \"currency\": \"USD\"\n}"
        }
      }
    },
    {
      "name": "Calculate - Domestic Germany physical B2C (19%)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/tax/calculate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sellerCountry\": \"DE\",\n  \"buyerCountry\": \"DE\",\n  \"productType\": \"PHYSICAL\",\n  \"transactionType\": \"B2C\",\n  \"netAmount\": 250.0,\n  \"currency\": \"EUR\"\n}"
        }
      }
    },
    {
      "name": "Calculate - EU to EU B2B (0% reverse charge)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/tax/calculate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sellerCountry\": \"DE\",\n  \"buyerCountry\": \"FR\",\n  \"productType\": \"PHYSICAL\",\n  \"transactionType\": \"B2B\",\n  \"netAmount\": 1000.0,\n  \"currency\": \"EUR\"\n}"
        }
      }
    },
    {
      "name": "Calculate - LATAM export physical to EU (0%, import VAT on buyer)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/tax/calculate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sellerCountry\": \"BR\",\n  \"buyerCountry\": \"FR\",\n  \"productType\": \"PHYSICAL\",\n  \"transactionType\": \"B2C\",\n  \"netAmount\": 250.0,\n  \"currency\": \"EUR\"\n}"
        }
      }
    },
    {
      "name": "Calculate - Reduced rate BOOKS + reporting currency (both stretch goals)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/tax/calculate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sellerCountry\": \"FR\",\n  \"buyerCountry\": \"DE\",\n  \"productType\": \"PHYSICAL\",\n  \"transactionType\": \"B2C\",\n  \"netAmount\": 100.0,\n  \"currency\": \"EUR\",\n  \"productCategory\": \"BOOKS\",\n  \"reportingCurrency\": \"USD\"\n}"
        }
      }
    },
    {
      "name": "Calculate - Invalid country (400 error example)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/tax/calculate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sellerCountry\": \"US\",\n  \"buyerCountry\": \"DE\",\n  \"productType\": \"PHYSICAL\",\n  \"transactionType\": \"B2C\",\n  \"netAmount\": 100.0,\n  \"currency\": \"USD\"\n}"
        }
      }
    },
